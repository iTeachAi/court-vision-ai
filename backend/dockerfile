# ─────────────────────────────────────────────
# Stage 1: dependency builder
# ─────────────────────────────────────────────
FROM python:3.11-slim AS builder

WORKDIR /install

COPY requirements.txt .

# Install to an isolated prefix so we can copy cleanly
RUN pip install --no-cache-dir --prefix=/install/deps -r requirements.txt


# ─────────────────────────────────────────────
# Stage 2: runtime image
# ─────────────────────────────────────────────
FROM python:3.11-slim

WORKDIR /app

# System deps:
#   ffmpeg       — video re-encoding (libx264)
#   libgl1       — OpenCV requirement
#   libglib2.0-0 — OpenCV requirement (glib / gthread)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy pre-built Python packages from builder stage
COPY --from=builder /install/deps /usr/local

# Copy application code
COPY app.py .

# Copy model weights if they exist at build time (optional)
# Remove these lines if you mount the weights as a volume instead
COPY best.pt* ./

# Create temp directory for video processing
RUN mkdir -p /app/temp

# Non-root user for security
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000

# --workers 1: model is loaded once globally; multiple workers = multiple model copies in RAM
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]